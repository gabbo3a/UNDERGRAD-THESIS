{
  "name": "Lean4-LaTeX",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "leanprover.lean4",
        "James-Yu.latex-workshop"
      ],
      "settings": {
        "lean4.serverEnvPaths": [
          "thesis-project",
          "playground/exercises"
        ],
        "latex-workshop.latex.outDir": "../build",
        "latex-workshop.latex.recipes": [
          {
            "name": "latexmk",
            "tools": ["latexmk"]
          }
        ],
        "latex-workshop.latex.tools": [
          {
            "name": "latexmk",
            "command": "latexmk",
            "args": [
              "-synctex=1",
              "-interaction=nonstopmode",
              "-file-line-error",
              "-pdf",
              "-outdir=../build",
              "%DOC%"
            ]
          }
        ]
      }
    }
  },
  "remoteUser": "luser"
}